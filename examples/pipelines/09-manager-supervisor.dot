// 09-manager-supervisor.dot -- Manager loop (supervisor) pattern.
//
// A pipeline with a manager/supervisor that oversees a sub-pipeline
// using an observe/evaluate/act cycle.
// Tests: manager_loop handler (shape=house), max_cycles, stop_condition,
//        poll_interval, actions (observe/steer/wait), subgraph execution,
//        child context cloning, steering injection, cycle telemetry.

digraph ManagerSupervisor {
    graph [
        goal="Build and test a data pipeline that processes CSV files into a normalized database",
        label="Manager Supervisor Pipeline"
    ]
    rankdir=TB

    // Structural nodes
    start [shape=Mdiamond, label="Start"]
    done  [shape=Msquare, label="Done"]

    // Stage 1: High-level planning
    plan [
        label="Plan",
        prompt="Create a high-level plan for: $goal\nBreak it into implementation steps: schema design, CSV parser, data transformer, database writer, and integration tests."
    ]

    // Manager loop node -- shape=house triggers ManagerLoopHandler.
    // The manager supervises the child subgraph (implement -> test cycle),
    // re-running it each cycle with steering context when the child fails.
    //
    // On each cycle:
    //   1. OBSERVE: Clone context, inject steering (if steer enabled), run child
    //   2. EVALUATE: Check stop_condition or default guard (child success)
    //   3. ACT: Wait poll_interval before next cycle
    manager [
        shape=house,
        label="Supervise Implementation",
        prompt="Oversee the implementation and testing cycle. Steer the child toward success.",
        manager.max_cycles=5,
        manager.poll_interval="0s",
        manager.stop_condition="outcome=success",
        manager.actions="observe,steer,wait"
    ]

    // Child subgraph nodes -- these are executed by the manager on each cycle.
    // The manager's first outgoing edge determines the child start node.
    implement [
        label="Implement",
        prompt="Implement the data pipeline: CSV parser, data transformer, and database writer. Follow the plan from the planning phase. If steering feedback is provided, incorporate it."
    ]

    test [
        label="Test",
        prompt="Run the test suite for the data pipeline. Test CSV parsing, data transformation, and database writing. Report success if all tests pass."
    ]

    gate [
        shape=diamond,
        label="Tests Pass?"
    ]

    // Report on what the manager accomplished
    report [
        label="Report",
        prompt="Summarize the implementation results. How many cycles did the manager need? What was the final outcome?"
    ]

    // Flow: start -> plan -> manager -> report -> done
    start -> plan -> manager

    // Manager's child subgraph starts at implement (first outgoing edge)
    manager -> implement

    // Child subgraph flow
    implement -> test -> gate
    gate -> done [label="Pass", condition="outcome=success"]
    gate -> implement [label="Fail", condition="outcome!=success"]

    // After manager completes, continue to report
    manager -> report [weight=0]
    report -> done
}
