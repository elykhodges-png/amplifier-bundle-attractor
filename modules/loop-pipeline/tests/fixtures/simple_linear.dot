digraph SimpleLinear {
    graph [goal="Implement a simple feature"]

    start     [shape=Mdiamond, label="Start"]
    implement [label="Implement", prompt="Implement the feature based on: $goal"]
    validate  [label="Validate", prompt="Run tests to validate the implementation"]
    exit      [shape=Msquare, label="Exit"]

    start -> implement -> validate -> exit
}
