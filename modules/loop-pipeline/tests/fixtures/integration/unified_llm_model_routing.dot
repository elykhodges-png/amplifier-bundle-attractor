digraph ModelRouting {
    graph [
        goal="Analyze code",
        model_stylesheet="* { llm_provider: anthropic; llm_model: claude-sonnet-4-20250514; } .fast { llm_provider: openai; llm_model: gpt-4.1-mini; }"
    ]

    start [shape=Mdiamond]
    analyze [shape=box, class="fast", prompt="Quick analysis of: $goal"]
    deep_review [shape=box, prompt="Deep review of: $goal"]
    done [shape=Msquare]

    start -> analyze -> deep_review -> done
}
