digraph GoalGate {
    graph [goal="Create a hello world Python script"]

    start     [shape=Mdiamond, label="Start"]
    implement [label="Implement", prompt="Write the code for: $goal", goal_gate=true, retry_target="implement"]
    review    [label="Review", prompt="Review the code for correctness"]
    exit      [shape=Msquare, label="Exit"]

    start -> implement
    implement -> review [condition="outcome=success"]
    implement -> implement [condition="outcome=fail", label="Retry"]
    review -> exit [condition="outcome=success"]
    review -> implement [condition="outcome=fail", label="Fix"]
}
