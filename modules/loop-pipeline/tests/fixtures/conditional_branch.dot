digraph ConditionalBranch {
    graph [goal="Implement and validate a feature"]
    node [shape=box]

    start     [shape=Mdiamond, label="Start"]
    implement [label="Implement", prompt="Implement the feature based on: $goal"]
    test      [label="Run Tests", prompt="Run the test suite"]
    exit      [shape=Msquare, label="Exit"]

    start -> implement -> test
    test -> exit      [label="Pass", condition="outcome=success"]
    test -> implement [label="Fail", condition="outcome=fail"]
}
